<%- include('partials/header', { title: title }) %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h4 mb-3"><%= formTitle %></h1>
        <p class="text-muted">Fill out the employee details below.</p>

        <% if (alert && alert.text) { %>
          <div class="alert alert-<%= alert.type %>" role="alert">
            <%= alert.text %>
          </div>
        <% } %>

        <form action="<%= formAction %>" method="POST" class="row g-3">
          <div class="col-md-6">
            <label for="name" class="form-label">Name</label>
            <input
              type="text"
              class="form-control"
              id="name"
              name="name"
              value="<%= employee.name || '' %>"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              value="<%= employee.email || '' %>"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="designation" class="form-label">Designation</label>
            <input
              type="text"
              class="form-control"
              id="designation"
              name="designation"
              value="<%= employee.designation || '' %>"
            />
          </div>

          <div class="col-md-6">
            <label for="department" class="form-label">Department</label>
            <select class="form-select" id="department" name="department">
              <option value="">Select Department</option>
              <% departments.forEach(function(dep) { %>
                <option value="<%= dep.name %>" <%= (employee.department || '') === dep.name ? 'selected' : '' %>>
                  <%= dep.name %>
                </option>
              <% }); %>
            </select>
          </div>

          <div class="col-md-6">
            <label for="salary" class="form-label">Salary</label>
            <input
              type="number"
              min="0.01"
              step="0.01"
              class="form-control"
              id="salary"
              name="salary"
              value="<%= employee.salary !== undefined ? employee.salary : '' %>"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="joiningDate" class="form-label">Joining Date</label>
            <input
              type="date"
              class="form-control"
              id="joiningDate"
              name="joiningDate"
              value="<%= employee.joiningDate ? new Date(employee.joiningDate).toISOString().split('T')[0] : '' %>"
            />
          </div>

          <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
            <a href="/" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
