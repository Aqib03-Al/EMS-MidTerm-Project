<%- include('partials/header', { title: title }) %>

<div class="hero-panel d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1 text-white">Admin Dashboard</h1>
    <p class="text-white-50 mb-0">Monitor and manage your organization with a professional control center.</p>
  </div>
  <% if (userRole === 'admin') { %>
    <a href="/employees/new" class="btn btn-light fw-semibold">+ Add Employee</a>
  <% } %>
</div>

<% if (alert && alert.text) { %>
  <div class="alert alert-<%= alert.type %> alert-dismissible fade show" role="alert">
    <%= alert.text %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="stat-card stat-card-indigo">
      <p class="stat-label mb-1">Total Employees</p>
      <h2 class="stat-value mb-0"><%= stats.totalEmployees %></h2>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card stat-card-blue">
      <p class="stat-label mb-1">Departments</p>
      <h2 class="stat-value mb-0"><%= stats.totalDepartments %></h2>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card stat-card-cyan">
      <p class="stat-label mb-1">Joined in 30 Days</p>
      <h2 class="stat-value mb-0"><%= stats.recentEmployees %></h2>
    </div>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form action="/" method="GET" class="row g-3">
      <div class="col-md-6">
        <label for="search" class="form-label">Search by Name</label>
        <input
          type="text"
          class="form-control"
          id="search"
          name="search"
          value="<%= search %>"
          placeholder="Enter employee name"
        />
      </div>
      <div class="col-md-4">
        <label for="department" class="form-label">Department Filter</label>
        <select class="form-select" id="department" name="department">
          <option value="">All Departments</option>
          <% departments.forEach(function(dep) { %>
            <option value="<%= dep.name %>" <%= selectedDepartment === dep.name ? 'selected' : '' %>><%= dep.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-2 d-grid align-self-end">
        <button type="submit" class="btn btn-outline-primary">Apply</button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0 align-middle">
        <thead class="table-dark">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Designation</th>
            <th>Department</th>
            <th>Salary</th>
            <th>Joining Date</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (employees.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">No employees found.</td>
            </tr>
          <% } %>
          <% employees.forEach(function(employee) { %>
            <tr>
              <td><%= employee.name %></td>
              <td><%= employee.email %></td>
              <td><%= employee.designation || 'N/A' %></td>
              <td><span class="badge text-bg-light border"><%= employee.department || 'N/A' %></span></td>
              <td>PKR <%= Number(employee.salary).toLocaleString() %></td>
              <td><%= new Date(employee.joiningDate).toLocaleDateString() %></td>
              <td class="text-center">
                <% if (userRole === 'admin') { %>
                  <div class="d-flex justify-content-center gap-2">
                    <a href="/employees/<%= employee._id %>/edit" class="btn btn-sm btn-primary">Edit</a>
                    <form action="/employees/<%= employee._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this employee?');">
                      <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="badge text-bg-secondary">Read Only</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
